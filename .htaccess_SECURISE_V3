# =================================================================
# .htaccess SÉCURISÉ OPTIMISÉ pour OceanPhenix + O2Switch
# Version: 3.0 - 23/02/2026 - Sécurité renforcée A+
# =================================================================
# 
# INSTRUCTIONS D'INSTALLATION:
# 1. Sauvegarder l'ancien .htaccess
# 2. Remplacer par ce fichier
# 3. Tester le site après upload
# 4. Vérifier avec https://securityheaders.com/
# 
# =================================================================

# Configuration de base O2Switch
ServerSignature Off
Options -Indexes -MultiViews +FollowSymLinks
DirectoryIndex index.html index.htm

# =================================================================
# SÉCURITÉ RENFORCÉE - NIVEAU A+
# =================================================================

# Force HTTPS (vérifier que SSL est actif sur O2Switch)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Redirection www vers non-www (O2Switch compatible)
    RewriteCond %{HTTP_HOST} ^www\.oceanphenix\.fr$ [NC]
    RewriteRule ^(.*)$ https://oceanphenix.fr/$1 [L,R=301]
    
    # Force HTTPS (O2Switch SSL)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Headers de Sécurité OPTIMISÉS
<IfModule mod_headers.c>
    # HSTS - Force HTTPS pendant 2 ans (PRELOAD pour A+)
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" env=HTTPS
    
    # Clickjacking Protection - DENY pour score maximal
    Header always set X-Frame-Options "DENY"
    
    # XSS Protection (legacy mais toujours utile)
    Header always set X-XSS-Protection "1; mode=block"
    
    # MIME-Type Sniffing Protection
    Header always set X-Content-Type-Options "nosniff"
    
    # Referrer Policy (privacy-first)
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content-Security-Policy DURCIE (sans unsafe-inline)
    # IMPORTANT: Utiliser des nonces ou hash dans le HTML pour les scripts inline
    # Pour simplifier, on autorise encore unsafe-inline mais de manière plus stricte
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests; block-all-mixed-content;"
    
    # Permissions-Policy (désactive features non utilisées)
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=(), magnetometer=(), gyroscope=(), accelerometer=(), ambient-light-sensor=(), autoplay=(), encrypted-media=(), picture-in-picture=()"
    
    # Cross-Origin Policies pour isolation maximale
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    # Cross-Origin-Embedder-Policy ASSOUPLI pour compatibilité CDN
    Header always set Cross-Origin-Embedder-Policy "credentialless"
    
    # Server Header - Masquer version Apache
    Header always unset Server
    Header always unset X-Powered-By
</IfModule>

# Protection fichiers sensibles
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(bak|backup|config|log|sql|md|json|lock|gitignore|env)$">
    Require all denied
</FilesMatch>

# Protection .well-known (autoriser security.txt)
<Directory ".well-known">
    <Files "security.txt">
        Require all granted
    </Files>
</Directory>

# Blocage bots malveillants ÉTENDU
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (nikto|curl|wget|scanner|bot|scraper|sqlmap|nmap|masscan|nessus|metasploit) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} (libwww-perl|python-requests|PhantomJS|headless|puppeteer|selenium) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} (HTTrack|WebCopier|WebZIP|WebReaper) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# Anti-Hotlinking (protège votre bande passante O2Switch)
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?oceanphenix\.fr [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(.*\.)?oceanphenix\.fr [NC]
    RewriteRule \.(jpg|jpeg|png|gif|webp|svg|mp4)$ - [F,NC,L]
</IfModule>

# =================================================================
# PERFORMANCE - COMPRESSION GZIP OPTIMISÉE
# =================================================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE font/woff2
    
    # Exceptions navigateurs anciens
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    
    # Niveau de compression optimisé (1-9, défaut 6)
    DeflateCompressionLevel 6
</IfModule>

# =================================================================
# PERFORMANCE - CACHE NAVIGATEUR OPTIMISÉ
# =================================================================

<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images - Cache ultra-long (immutable)
    ExpiresByType image/png "access plus 2 years"
    ExpiresByType image/jpg "access plus 2 years"
    ExpiresByType image/jpeg "access plus 2 years"
    ExpiresByType image/gif "access plus 2 years"
    ExpiresByType image/svg+xml "access plus 2 years"
    ExpiresByType image/webp "access plus 2 years"
    ExpiresByType image/avif "access plus 2 years"
    ExpiresByType image/x-icon "access plus 2 years"
    ExpiresByType video/mp4 "access plus 1 year"
    
    # CSS et JavaScript - Cache 1 mois (versionné)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # Fonts - Cache 1 an
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    
    # HTML - Cache court (mises à jour fréquentes)
    ExpiresByType text/html "access plus 1 hour"
    
    # Manifests et XML
    ExpiresByType application/manifest+json "access plus 1 week"
    ExpiresByType application/xml "access plus 1 hour"
    ExpiresByType text/xml "access plus 1 hour"
</IfModule>

# Cache-Control Headers (priorité sur Expires)
<IfModule mod_headers.c>
    # Images - Cache immutable
    <FilesMatch "\.(png|jpg|jpeg|gif|svg|webp|avif|ico)$">
        Header set Cache-Control "public, max-age=63072000, immutable"
        Header set Vary "Accept-Encoding"
        Header set Accept-Ranges "bytes"
    </FilesMatch>
    
    # CSS et JS - Cache avec revalidation
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000, must-revalidate"
    </FilesMatch>
    
    # HTML - Cache court avec revalidation
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
    
    # Fonts
    <FilesMatch "\.(woff|woff2|ttf|eot|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
    
    # Videos
    <FilesMatch "\.(mp4|webm|ogv)$">
        Header set Cache-Control "public, max-age=31536000"
        Header set Accept-Ranges "bytes"
    </FilesMatch>
</IfModule>

# =================================================================
# CORS - Restreint aux ressources publiques
# =================================================================

<IfModule mod_headers.c>
    # CORS uniquement pour images/fonts/videos
    <FilesMatch "\.(png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|mp4)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, OPTIONS"
    </FilesMatch>
</IfModule>

# =================================================================
# SEO - REDIRECTIONS & URL REWRITING
# =================================================================

<IfModule mod_rewrite.c>
    # URLs friendly
    RewriteRule ^accueil/?$ index.html [L]
    RewriteRule ^home/?$ index.html [L]
    RewriteRule ^oceanphenix/?$ index.html [L]
</IfModule>

# =================================================================
# ERROR PAGES PERSONNALISÉES
# =================================================================

ErrorDocument 404 /404.html
ErrorDocument 403 /403.html
ErrorDocument 500 /500.html

# =================================================================
# MIME TYPES (au cas où serveur pas à jour)
# =================================================================

<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType image/svg+xml .svg
    AddType image/webp .webp
    AddType image/avif .avif
    AddType font/woff .woff
    AddType font/woff2 .woff2
    AddType application/manifest+json .webmanifest
</IfModule>

# =================================================================
# UTF-8 Encoding
# =================================================================

AddDefaultCharset UTF-8
<IfModule mod_mime.c>
    AddCharset UTF-8 .html .css .js .xml .json .webmanifest
</IfModule>

