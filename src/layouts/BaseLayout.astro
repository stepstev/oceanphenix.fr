---
// src/layouts/BaseLayout.astro — Head SEO + wrapper global
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  lastModified?: string;
}

const {
  title = "OceanPhenix 2026 | Stéphane Celton - Data Product Manager & Innovation Tech",
  description = "Stéphane Celton - Data Product Manager certifié, Senior Data Analyst BI, Production Engineer. 15+ ans d'expertise IT, innovation data & IA, solutions métier impactantes.",
  lastModified = "03/03/2026 12:00",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="last-modified" content={lastModified} />
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
  <meta http-equiv="Pragma" content="no-cache" />
  <meta http-equiv="Expires" content="0" />
  <meta http-equiv="X-Content-Type-Options" content="nosniff" />
  <meta http-equiv="X-XSS-Protection" content="1; mode=block" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=()" />
  <link rel="icon" type="image/svg+xml" href="/Images/logos/favicon.svg" />
  <link rel="alternate icon" type="image/png" href="/Images/logos/ThinkinGboulversement_50.png" />
  <link rel="apple-touch-icon" href="/Images/logos/ThinkinGboulversement_50.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=Roboto:wght@300;400;500;700&display=swap"
    rel="stylesheet"
    crossorigin="anonymous"
  />
  <link
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    rel="stylesheet"
    integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
    crossorigin="anonymous"
    referrerpolicy="no-referrer"
  />
</head>
<body>
  <slot />
  <!-- JS main — chargé en fin de body comme l'original -->
  <script src="/js/main.js" is:inline></script>
</body>
</html>
