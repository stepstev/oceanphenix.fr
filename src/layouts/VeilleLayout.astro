---
// src/layouts/VeilleLayout.astro — Layout pour pages Veille/MDX
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import OceanBackground from '../components/OceanBackground.astro';
import Footer from '../components/Footer.astro';
import CopyrightBar from '../components/CopyrightBar.astro';

export interface Props {
  title?: string;
  description?: string;
  frontmatter?: {
    title?: string;
    description?: string;
  };
}

const {
  title,
  description,
  frontmatter,
} = Astro.props;

const pageTitle = title ?? frontmatter?.title ?? "Veille & Publications | OceanPhenix";
const pageDescription = description ?? frontmatter?.description ?? "";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <OceanBackground />
  <Nav />

  <main class="main-content veille-page">
    <div class="container">
      <slot />
    </div>
  </main>

  <Footer />
  <CopyrightBar />
</BaseLayout>

<style is:global>
  .veille-page {
    padding-top: 5rem;
    min-height: 100vh;
  }
  .veille-page .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  /* Hero */
  .veille-hero {
    padding: var(--spacing-xxl) 0 var(--spacing-lg);
    text-align: center;
  }
  .veille-hero h1 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    margin: var(--spacing-sm) 0;
  }
  .veille-intro {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Titres */
  .veille-page h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-light);
    margin: var(--spacing-xl) 0 var(--spacing-md);
  }

  /* HR */
  .veille-page hr {
    border: none;
    border-top: 1px solid rgba(0, 217, 255, 0.15);
    margin: var(--spacing-xl) 0;
  }

  /* Tableaux */
  .veille-page table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--spacing-md);
    font-size: 0.9rem;
  }
  .veille-page thead tr {
    background: rgba(0, 217, 255, 0.08);
    border-bottom: 1px solid rgba(0, 217, 255, 0.25);
  }
  .veille-page th {
    padding: 0.75rem 1rem;
    text-align: left;
    color: var(--accent-cyan);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .veille-page td {
    padding: 0.75rem 1rem;
    color: var(--text-muted);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    vertical-align: top;
    line-height: 1.5;
  }
  .veille-page tbody tr:hover {
    background: rgba(0, 217, 255, 0.04);
  }
  .veille-page td:first-child {
    white-space: nowrap;
    color: var(--accent-cyan);
    font-weight: 500;
    font-size: 0.82rem;
  }
  .veille-page a {
    color: var(--accent-light-cyan);
    text-decoration: none;
    transition: var(--transition-fast);
  }
  .veille-page a:hover {
    color: var(--accent-cyan);
    text-decoration: underline;
  }

  /* Boutons */
  .veille-cta-row {
    margin: var(--spacing-md) 0;
  }
  .veille-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    border-radius: var(--radius-full);
    background: var(--accent-gradient);
    color: var(--primary-dark) !important;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none !important;
    transition: var(--transition-medium);
  }
  .veille-btn:hover {
    box-shadow: var(--shadow-glow);
    transform: translateY(-2px);
    text-decoration: none !important;
  }
  .veille-btn-ghost {
    background: rgba(255,255,255,0.06) !important;
    color: var(--text-muted) !important;
    border: 1px solid rgba(255,255,255,0.12);
  }
  .veille-btn-ghost:hover {
    background: rgba(255,255,255,0.1) !important;
    color: var(--white) !important;
    box-shadow: none;
  }
  .veille-back {
    padding: var(--spacing-lg) 0 var(--spacing-xxl);
  }

  @media (max-width: 768px) {
    .veille-page table { font-size: 0.8rem; }
    .veille-page th,
    .veille-page td { padding: 0.6rem 0.6rem; }
  }
</style>
