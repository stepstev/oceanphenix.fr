---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page non trouvée | OceanPhenix">
  <div style="display:flex;flex-direction:column;justify-content:center;align-items:center;min-height:100vh;font-family:'IBM Plex Sans',sans-serif;background:#0d1117;color:#f8f9fa;text-align:center;padding:2rem;">
    <h1 style="font-size:6rem;font-weight:700;background:linear-gradient(135deg,#00d9ff,#5ce1e6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0;">404</h1>
    <p style="font-size:1.5rem;color:#c5d0de;margin:1rem 0 2rem;">Page non trouvée</p>
    <a href="/" style="padding:0.8rem 2rem;background:linear-gradient(135deg,#00d9ff,#0095d9);color:#fff;text-decoration:none;border-radius:50px;font-weight:600;">
      Retour à l'accueil
    </a>
  </div>
</BaseLayout>
