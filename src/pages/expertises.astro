---
// src/pages/expertises.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import OceanBackground from '../components/OceanBackground.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CopyrightBar from '../components/CopyrightBar.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout
  title="Expertises — Stéphane Celton | Data Product Manager | OceanPhenix"
  description="Domaines d'intervention : Data Product Management, Business Intelligence, Power BI, Gouvernance Data, Observabilité, Architecture Data. +20 ans en environnements critiques (banque, industrie, énergie)."
  canonical="https://oceanphenix.fr/expertises"
>
  <script type="application/ld+json" slot="head">
  {JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Stéphane Celton",
    "url": "https://oceanphenix.fr/expertises",
    "jobTitle": "Data Product Manager",
    "knowsAbout": [
      "Data Product Management","Business Intelligence","Power BI","TMDL","Gouvernance Data","Architecture décisionnelle","Observabilité","MCO","Production IT","Agile","SQL","Python"
    ]
  })}
  </script>

  <OceanBackground />
  <Nav />

  <main class="exp-main">

    <div class="exp-header">
      <div class="exp-badge">
        DOMAINES D'INTERVENTION
      </div>
      <h1 class="exp-title">Expertises</h1>
      <p class="exp-tagline">
        Parcours en conception Ingénierie de Production, industrialisation de solutions data<br>
        au sein d'environnements exigeants : <strong>banque, industrie, énergie</strong>.
      </p>
      <a href="https://stephanecelton.oceanphenix.fr/" target="_blank" rel="noopener" class="exp-cta">
        Voir le portfolio complet
      </a>
    </div>

    <div class="exp-grid">

      <!-- DATA PRODUCT MANAGEMENT -->
      <div class="exp-card">
        <h2 class="exp-card-title"><i class="fa-solid fa-layer-group exp-title-icon"></i>Data Product Management</h2>
        <ul class="exp-list">
          <li>Cadrage et structuration des usages data</li>
          <li>Définition et pilotage de la roadmap produit</li>
          <li>Priorisation orientée valeur métier</li>
          <li>Ownership fonctionnel des assets data</li>
          <li>Alignement avec les parties prenantes</li>
        </ul>
      </div>

      <!-- BUSINESS INTELLIGENCE -->
      <div class="exp-card">
        <h2 class="exp-card-title"><i class="fa-solid fa-chart-column exp-title-icon"></i>Business Intelligence &amp; Data Platforms</h2>
        <ul class="exp-list">
          <li>Architecture décisionnelle (Lakehouse, DWH)</li>
          <li>Power BI — modélisation TMDL, DAX avancé</li>
          <li>Structuration des modèles sémantiques</li>
          <li>Self-service BI maîtrisé</li>
          <li>Reporting opérationnel et exécutif</li>
        </ul>
      </div>

      <!-- GOUVERNANCE -->
      <div class="exp-card">
        <h2 class="exp-card-title"><i class="fa-solid fa-shield-halved exp-title-icon"></i>Gouvernance &amp; Fiabilité des Données</h2>
        <ul class="exp-list">
          <li>Politique qualité des données</li>
          <li>Indicateurs de fiabilité et traçabilité</li>
          <li>Documentation des assets (data catalog)</li>
          <li>Conformité et contrôle de la donnée</li>
          <li>Stewardship et ownership data</li>
        </ul>
      </div>

      <!-- INDUSTRIALISATION -->
      <div class="exp-card">
        <h2 class="exp-card-title"><i class="fa-solid fa-gears exp-title-icon"></i>Industrialisation &amp; Observabilité</h2>
        <ul class="exp-list">
          <li>MCO des plateformes data et BI</li>
          <li>Monitoring data et indicateurs de production</li>
          <li>Observabilité des systèmes data</li>
          <li>Automatisation raisonnée des flux</li>
          <li>CI/CD appliqué à la data (TMDL, Git)</li>
        </ul>
      </div>

      <!-- IA & RAG -->
      <div class="exp-card exp-card--featured">
        <h2 class="exp-card-title"><i class="fa-solid fa-brain exp-title-icon"></i>IA Appliquée &amp; RAG Souverain</h2>
        <ul class="exp-list">
          <li>Architecture RAG sur infrastructure souveraine</li>
          <li>LLM locaux (Ollama, Mistral, LLaMA)</li>
          <li>Intégration IA dans les processus data</li>
          <li>Évaluation pragmatique des cas d'usage IA</li>
          <li>POC et prototypage orienté métier</li>
        </ul>
      </div>

      <!-- PILOTAGE -->
      <div class="exp-card exp-card--featured">
        <h2 class="exp-card-title"><i class="fa-solid fa-gauge-high exp-title-icon"></i>Pilotage IT &amp; Production</h2>
        <ul class="exp-list">
          <li>Production Engineer — systèmes critiques</li>
          <li>Gestion des incidents et de la continuité</li>
          <li>Supervision et alerting opérationnel</li>
          <li>Agile / Scrum — pilotage des livraisons</li>
          <li>Coordination équipes techniques et MOA</li>
        </ul>
      </div>

    </div>

    <!-- Environnements sectoriels -->
    <div class="exp-sectors">
      <div class="exp-sectors-label">
        Environnements sectoriels
      </div>
      <div class="exp-sectors-list">
        <span class="exp-sector">Banque &amp; Assurance</span>
        <span class="exp-sector">Énergie</span>
        <span class="exp-sector">Industrie</span>
        <span class="exp-sector">Aéronautique &amp; Défense</span>
        <span class="exp-sector">Santé &amp; Services publics</span>
      </div>
    </div>


  </main>

  <Footer />
  <CopyrightBar />

</BaseLayout>

<style>
  .exp-main {
    position: relative;
    z-index: 10;
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Header */
  .exp-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .exp-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(0, 217, 255, 0.05);
    border: 1px solid rgba(0, 217, 255, 0.18);
    color: #00d9ff;
    font-size: 0.70rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0.4rem 1.1rem;
    border-radius: 50px;
    margin-bottom: 1.2rem;
  }

  .exp-badge-icon {
    width: 0.9rem;
    height: 0.9rem;
    stroke-width: 2.2;
  }

  .exp-title {
    font-size: 2.5rem;
    font-weight: 300;
    color: #c5d0de;
    -webkit-text-fill-color: #c5d0de;
    letter-spacing: -0.5px;
    margin: 0 0 1rem;
  }

  .exp-tagline {
    font-size: 1.2rem;
    color: #c5d0de;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .exp-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: transparent;
    border: 1px solid rgba(0, 217, 255, 0.35);
    color: #00d9ff;
    padding: 0.55rem 1.4rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s;
    position: relative;
  }

  .exp-cta::after {
    content: '';
    position: absolute;
    top: -3px;
    right: -3px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.85;
    animation: btn-dot-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    pointer-events: none;
  }

  .exp-cta:hover {
    background: rgba(0, 217, 255, 0.1);
    box-shadow: 0 0 16px rgba(0, 217, 255, 0.2);
  }
  .exp-cta:hover::after {
    opacity: 0;
    animation: none;
  }

  .exp-cta-icon {
    width: 0.9rem;
    height: 0.9rem;
    stroke-width: 2.2;
  }

  /* Grid */
  .exp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 900px) {
    .exp-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 580px) {
    .exp-grid { grid-template-columns: 1fr; }
  }

  /* Card */
  .exp-card {
    background: rgba(10, 25, 41, 0.85);
    border: 1px solid rgba(0, 180, 216, 0.18);
    border-radius: 12px;
    padding: 1.6rem 1.4rem;
    transition: border-color 0.2s, transform 0.22s, box-shadow 0.22s;
    position: relative;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
  }

  .exp-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #ff7a1a, #f97316, #ffad6b);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
    pointer-events: none;
    z-index: 1;
  }

  .exp-card:hover::before {
    transform: scaleX(1);
  }

  .exp-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.28);
    border-color: rgba(0, 180, 216, 0.35);
  }

  .exp-card--featured {
    border-color: rgba(0, 149, 217, 0.25);
  }

  .exp-card--featured:hover {
    box-shadow: 0 8px 28px rgba(0, 80, 160, 0.18);
    border-color: rgba(0, 149, 217, 0.42);
  }

  /* Icon wrapper */
  .exp-card-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    background: rgba(0, 217, 255, 0.08);
    border: 1px solid rgba(0, 217, 255, 0.18);
    border-radius: 10px;
    margin-bottom: 1rem;
    color: #00d9ff;
  }

  .exp-card--featured .exp-card-icon-wrap {
    background: rgba(92, 225, 230, 0.08);
    border-color: rgba(92, 225, 230, 0.22);
    color: #5ce1e6;
  }

  .exp-card-icon {
    width: 1.25rem;
    height: 1.25rem;
    stroke-width: 1.8;
  }

  .exp-card-title {
    display: flex;
    align-items: center;
    gap: 0.70rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: #f8f9fa;
    margin: 0 0 0.9rem;
    line-height: 1.3;
  }

  .exp-title-icon {
    font-size: 1.8rem;
    color: var(--accent-cyan, #00d9ff);
    flex-shrink: 0;
    opacity: 1;
    line-height: 1;
  }

  .exp-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .exp-list li {
    font-size: 0.875rem;
    color: #a8bfd0;
    padding-left: 1rem;
    position: relative;
    line-height: 1.5;
  }

  .exp-list li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: #00d9ff;
    font-weight: 700;
  }

  .exp-card--featured .exp-list li::before {
    color: #5ce1e6;
  }

  .exp-sectors {
    background: rgba(10, 25, 41, 0.6);
    border: 1px solid rgba(0, 180, 216, 0.10);
    border-radius: 14px;
    padding: 1.4rem 1.8rem;
    margin-bottom: 3rem;
    text-align: center;
  }

  .exp-sectors-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(0, 217, 255, 0.65);
    margin-bottom: 1.1rem;
  }

  .exp-sectors-icon {
    width: 0.85rem;
    height: 0.85rem;
    stroke-width: 2;
  }

  .exp-sectors-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .exp-sector {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(0, 217, 255, 0.04);
    border: 1px solid rgba(0, 180, 216, 0.14);
    color: #c5d0de;
    padding: 0.38rem 0.9rem;
    border-radius: 50px;
    font-size: 0.82rem;
    font-weight: 500;
    transition: border-color 0.2s, color 0.2s;
  }

  .exp-sector:hover {
    border-color: rgba(0, 217, 255, 0.35);
    color: #e8f4f8;
  }

  .exp-sector-icon {
    width: 0.85rem;
    height: 0.85rem;
    stroke-width: 2;
    color: rgba(0, 217, 255, 0.55);
  }

  /* ── Light theme overrides ── */
  :global([data-theme="light"]) .exp-badge {
    background: rgba(0, 119, 168, 0.08);
    border-color: rgba(0, 119, 168, 0.32);
    color: #005f8a;
  }

  :global([data-theme="light"]) .exp-title {
    color: #005f8a;
    -webkit-text-fill-color: #005f8a;
    font-weight: 600;
  }

  :global([data-theme="light"]) .exp-tagline {
    color: #3a5268;
  }

  :global([data-theme="light"]) .exp-cta {
    border-color: rgba(0, 100, 160, 0.35);
    color: #005f8a;
  }

  :global([data-theme="light"]) .exp-cta:hover {
    background: rgba(0, 100, 160, 0.07);
    box-shadow: 0 0 14px rgba(0, 100, 160, 0.18);
  }

  :global([data-theme="light"]) .exp-card {
    background: rgba(255, 255, 255, 0.92);
    border-color: rgba(10, 24, 44, 0.10);
    box-shadow: 0 2px 12px rgba(0, 80, 130, 0.06);
  }

  :global([data-theme="light"]) .exp-card:hover {
    box-shadow: 0 8px 24px rgba(0, 80, 130, 0.12);
    border-color: rgba(10, 24, 44, 0.18);
  }

  :global([data-theme="light"]) .exp-card--featured {
    border-color: rgba(10, 24, 44, 0.14);
  }

  :global([data-theme="light"]) .exp-card--featured:hover {
    box-shadow: 0 8px 28px rgba(0, 80, 130, 0.14);
    border-color: rgba(10, 24, 44, 0.22);
  }

  :global([data-theme="light"]) .exp-card-icon-wrap {
    background: rgba(0, 119, 168, 0.08);
    border-color: rgba(0, 119, 168, 0.22);
    color: #0077a8;
  }

  :global([data-theme="light"]) .exp-card--featured .exp-card-icon-wrap {
    background: rgba(0, 149, 201, 0.08);
    border-color: rgba(0, 149, 201, 0.24);
    color: #0095c9;
  }

  :global([data-theme="light"]) .exp-card-title {
    color: #0d1b2a;
  }

  :global([data-theme="light"]) .exp-list li {
    color: #3a5268;
  }

  :global([data-theme="light"]) .exp-list li::before {
    color: #0077a8;
  }

  :global([data-theme="light"]) .exp-card--featured .exp-list li::before {
    color: #0095c9;
  }

  :global([data-theme="light"]) .exp-sectors {
    background: rgba(255, 255, 255, 0.75);
    border-color: rgba(0, 100, 160, 0.15);
  }

  :global([data-theme="light"]) .exp-sectors-label {
    color: rgba(0, 95, 138, 0.75);
  }

  :global([data-theme="light"]) .exp-sector {
    background: rgba(0, 100, 160, 0.06);
    border-color: rgba(0, 100, 160, 0.2);
    color: #3a5268;
  }

  :global([data-theme="light"]) .exp-sector:hover {
    color: #0d1b2a;
    border-color: rgba(0, 100, 160, 0.42);
  }

  :global([data-theme="light"]) .exp-btn-demo {
    background: rgba(0, 100, 160, 0.07);
    border-color: rgba(0, 100, 160, 0.28);
    color: #005f8a;
  }

</style>
