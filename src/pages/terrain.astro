---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CopyrightBar from '../components/CopyrightBar.astro';
import CguModal from '../components/CguModal.astro';
import OceanBackground from '../components/OceanBackground.astro';
import TerrainDashboard from '../components/TerrainDashboard.astro';
import '../styles/terrain.css';
import '../styles/terrain-dashboard.css';
import etapesData from '../data/terrain-etapes.json';

const etapes = etapesData.etapes;
const position = etapesData.positionActuelle;
const journal = etapesData.journal;
const projet = etapesData.projet;
---

<BaseLayout
  title="Retour au Terrain — Besoins Data | OceanPhenix 2026"
  description="Parcours à vélo à travers la France pour rencontrer les entreprises, comprendre leurs besoins data réels et faciliter les échanges entre entreprises et freelances / consultants."
  lastModified="12/03/2026 12:00"
>
  <link slot="head" rel="stylesheet" href="/lib/leaflet.min.css" />
  <OceanBackground />
  <Nav />

  <!-- Guard: redirige vers admin-terrain si pas authentifié -->
  <script is:inline>
    (function() {
      var AUTH_KEY = 'op-admin-auth';
      var MAX_AGE = 3600000;
      var raw = sessionStorage.getItem(AUTH_KEY);
      var ok = false;
      if (raw) {
        try {
          var s = JSON.parse(raw);
          if (s.v === 2 && s.ts && (Date.now() - s.ts <= MAX_AGE)) ok = true;
        } catch(e) {}
      }
      if (!ok) { window.location.replace('/admin-terrain'); }
    })();
  </script>

  <main class="main-content terrain-page">

    <!-- ============================== -->
    <!-- 1. HERO                        -->
    <!-- ============================== -->
    <section class="terrain-hero" id="terrain-top">
      <div class="terrain-hero-inner">
        <div class="terrain-badge">
          <i class="fas fa-bicycle"></i>
          Projet Terrain 2026
        </div>
        <h1 class="terrain-hero-title">
          <span class="gradient-text">Retour au Terrain</span><br />
          <span>vers les Besoins Data</span>
        </h1>
        <p class="terrain-hero-subtitle">
          Un parcours à vélo à travers <strong id="live-nb-villes">{projet.nbEtapes} villes françaises</strong> pour aller à la rencontre des entreprises,
          comprendre leurs besoins réels autour de la data, identifier leurs pain points
          et faciliter les échanges entre entreprises et freelances&nbsp;/&nbsp;consultants.
        </p>
        <div class="terrain-hero-meta">
          <span><i class="fas fa-road"></i> <span id="live-km-total">{projet.kmTotal}</span> km</span>
          <span><i class="fas fa-map-marker-alt"></i> <span id="live-nb-etapes">{projet.nbEtapes}</span> étapes</span>
          <span><i class="fas fa-calendar-alt"></i> <span id="live-periode">{projet.periode}</span></span>
        </div>
        <div class="terrain-hero-actions">
          <a href="#carte" class="terrain-cta terrain-cta--primary">
            <i class="fas fa-map"></i> Voir la carte
          </a>
          <a href="#contact-terrain" class="terrain-cta terrain-cta--secondary">
            <i class="fas fa-handshake"></i> Me contacter
          </a>
        </div>
      </div>
    </section>

    <!-- ============================== -->
    <!-- DASHBOARD CARD (mockup style)  -->
    <!-- ============================== -->
    <TerrainDashboard />

    <!-- ============================== -->
    <!-- 2. VISION / DÉMARCHE           -->
    <!-- ============================== -->
    <section class="terrain-section" id="vision">
      <div class="terrain-container">
        <div class="terrain-section-badge">
          <i class="fas fa-eye"></i> VISION &amp; DÉMARCHE
        </div>
        <h2 class="terrain-section-title">
          <span class="gradient-text">Pourquoi ce projet&nbsp;?</span>
        </h2>
        <div class="terrain-vision-grid">
          <div class="terrain-vision-card">
            <div class="terrain-vision-icon"><i class="fas fa-comments"></i></div>
            <h3>Écouter le terrain</h3>
            <p>
              Trop de solutions data sont conçues loin des réalités métier. Ce projet remet l'humain au centre :
              aller directement dans les entreprises, écouter, comprendre, diagnostiquer.
            </p>
          </div>
          <div class="terrain-vision-card">
            <div class="terrain-vision-icon"><i class="fas fa-puzzle-piece"></i></div>
            <h3>Identifier les pain points</h3>
            <p>
              Chaque entreprise a des défis data uniques. Qualité des données, manque de pilotage,
              outils inadaptés, IA mal positionnée… L'objectif est de cartographier ces besoins réels.
            </p>
          </div>
          <div class="terrain-vision-card">
            <div class="terrain-vision-icon"><i class="fas fa-network-wired"></i></div>
            <h3>Connecter les acteurs</h3>
            <p>
              Faciliter les échanges entre entreprises et freelances / consultants spécialisés.
              Créer un réseau de confiance basé sur des besoins terrain, pas sur du marketing.
            </p>
          </div>
          <div class="terrain-vision-card">
            <div class="terrain-vision-icon"><i class="fas fa-bicycle"></i></div>
            <h3>Le vélo comme vecteur</h3>
            <p>
              Le vélo impose un rythme humain. Il ouvre les conversations, brise les codes corporates
              et montre un engagement authentique. C'est un choix délibéré, pas un gadget.
            </p>
          </div>
        </div>
        <div class="terrain-vision-admin">
          <p>
            <i class="fas fa-file-contract"></i>
            Recherche continue de sponsors pour soutenir le projet.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================== -->
    <!-- 3. CARTE INTERACTIVE           -->
    <!-- ============================== -->
    <section class="terrain-section terrain-section--map" id="carte">
      <div class="terrain-container terrain-container--wide">
        <div class="terrain-section-badge">
          <i class="fas fa-map-marked-alt"></i> PARCOURS
        </div>
        <h2 class="terrain-section-title">
          <span class="gradient-text">Carte du parcours</span>
        </h2>
        <p class="terrain-section-desc">
          Cliquez sur une étape pour voir les détails. Le tracé GPX est mis à jour en temps réel depuis l'admin.
        </p>
        <div id="terrain-map" class="terrain-map-container"></div>
        <div class="terrain-map-legend">
          <span class="legend-item"><span class="legend-dot legend-dot--actuel"></span> Position actuelle</span>
          <span class="legend-item"><span class="legend-dot legend-dot--planifie"></span> Étape planifiée</span>
          <span class="legend-item"><span class="legend-dot legend-dot--visite"></span> Étape visitée</span>
          <label class="legend-item legend-toggle" title="Afficher/masquer les espaces de coworking">
            <i class="fas fa-flag" style="color:#d4845a;"></i> Coworking
            <input type="checkbox" id="cw-toggle" checked />
            <span class="legend-switch"></span>
          </label>
          <label class="legend-item legend-toggle" title="Afficher/masquer pistes cyclables &amp; voies vertes">
            <i class="fas fa-bicycle" style="color:#2ea043;"></i> Pistes cyclables
            <input type="checkbox" id="cyclosm-toggle" checked />
            <span class="legend-switch"></span>
          </label>
          <label class="legend-item legend-toggle" title="Afficher/masquer routes vélo nationales">
            <i class="fas fa-route" style="color:#e04040;"></i> Routes vélo
            <input type="checkbox" id="waymarked-toggle" />
            <span class="legend-switch"></span>
          </label>
          <label class="legend-item legend-toggle" title="Afficher/masquer le tracé GPX du parcours">
            <i class="fas fa-map-signs" style="color:#f59e0b;"></i> Tracé GPX
            <input type="checkbox" id="gpx-toggle" checked />
            <span class="legend-switch"></span>
          </label>

        </div>
      </div>
    </section>

    <!-- ============================== -->
    <!-- 5. COMMENT JE PEUX AIDER       -->
    <!-- ============================== -->
    <section class="terrain-section" id="aider">
      <div class="terrain-container">
        <div class="terrain-section-badge">
          <i class="fas fa-hands-helping"></i> OFFRE DE CONSULTING
        </div>
        <h2 class="terrain-section-title">
          <span class="gradient-text">Offre de consulting Data &amp; BI</span>
        </h2>
        <div class="terrain-help-grid">
          <div class="terrain-help-card">
            <i class="fas fa-search-plus"></i>
            <h3>Diagnostic rapide de votre environnement data</h3>
            <p>Analyse de votre écosystème data pour identifier les points d'amélioration.</p>
            <ul class="terrain-help-list">
              <li>Outils BI et data existants</li>
              <li>Flux de données et sources</li>
              <li>Qualité et fiabilité des données</li>
              <li>Usages métiers et besoins décisionnels</li>
            </ul>
            <p class="terrain-help-objectif"><strong>Objectif :</strong> obtenir une vision claire de la situation et des priorités.</p>
          </div>
          <div class="terrain-help-card">
            <i class="fas fa-sitemap"></i>
            <h3>Structuration et gouvernance des données</h3>
            <p>Accompagnement pour mieux organiser et fiabiliser les données.</p>
            <ul class="terrain-help-list">
              <li>Définition de référentiels et sources de données fiables</li>
              <li>Organisation des flux et des responsabilités data</li>
              <li>Amélioration de la qualité et de la traçabilité des données</li>
            </ul>
            <p class="terrain-help-objectif"><strong>Objectif :</strong> disposer de données exploitables et cohérentes.</p>
          </div>
          <div class="terrain-help-card">
            <i class="fas fa-chart-line"></i>
            <h3>Pilotage par la donnée</h3>
            <p>Mise en place d'indicateurs et tableaux de bord adaptés aux besoins métiers.</p>
            <ul class="terrain-help-list">
              <li>Conception de dashboards BI</li>
              <li>Indicateurs de performance et suivi d'activité</li>
              <li>Visibilité sur les opérations et la qualité de service</li>
            </ul>
            <p class="terrain-help-objectif"><strong>Objectif :</strong> faciliter la prise de décision grâce à la donnée.</p>
          </div>
          <div class="terrain-help-card">
            <i class="fas fa-cogs"></i>
            <h3>Optimisation des processus data</h3>
            <p>Identification d'améliorations dans l'exploitation et la circulation des données.</p>
            <ul class="terrain-help-list">
              <li>Simplification des flux</li>
              <li>Automatisation de certains traitements</li>
              <li>Amélioration de la visibilité sur les systèmes</li>
            </ul>
            <p class="terrain-help-objectif"><strong>Objectif :</strong> rendre les processus plus efficaces et plus lisibles.</p>
          </div>
          <div class="terrain-help-card">
            <i class="fas fa-robot"></i>
            <h3>Évaluation pragmatique des usages IA</h3>
            <p>Analyse des cas où l'IA peut réellement apporter de la valeur.</p>
            <ul class="terrain-help-list">
              <li>Identification de cas d'usage pertinents</li>
              <li>Validation de la faisabilité</li>
              <li>Mise en perspective avec les données disponibles</li>
            </ul>
            <p class="terrain-help-objectif"><strong>Objectif :</strong> éviter les effets de mode et se concentrer sur les usages utiles.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================== -->
    <!-- 6. FORMULAIRE DE CONTACT       -->
    <!-- ============================== -->
    <section class="terrain-section" id="contact-terrain">
      <div class="terrain-container">
        <div class="terrain-section-badge">
          <i class="fas fa-envelope"></i> CONTACT
        </div>
        <h2 class="terrain-section-title">
          <span class="gradient-text">Me contacter</span>
        </h2>
        <p class="terrain-section-desc">
          Vous êtes une entreprise sur mon parcours ? Vous souhaitez organiser une rencontre, proposer un échange
          ou devenir sponsor ? Écrivez-moi&nbsp;!
        </p>
        <form
          class="terrain-contact-form"
          action="mailto:contact@oceanpconsulting.fr"
          method="POST"
          enctype="text/plain"
        >
          <div class="terrain-form-row">
            <div class="terrain-form-group">
              <label for="terrain-nom">Nom / Entreprise</label>
              <input type="text" id="terrain-nom" name="nom" required autocomplete="organization" />
            </div>
            <div class="terrain-form-group">
              <label for="terrain-email">Email</label>
              <input type="email" id="terrain-email" name="email" required autocomplete="email" />
            </div>
          </div>
          <div class="terrain-form-group">
            <label for="terrain-ville">Ville / Étape concernée</label>
            <select id="terrain-ville" name="ville">
              <option value="">— Sélectionnez —</option>
              {etapes.map((e) => (
                <option value={e.ville}>{e.ville} ({e.region})</option>
              ))}
            </select>
          </div>
          <div class="terrain-form-group">
            <label for="terrain-type">Type de demande</label>
            <select id="terrain-type" name="type">
              <option value="">— Sélectionnez —</option>
              <option value="rencontre">Organiser une rencontre</option>
              <option value="diagnostic">Demander un diagnostic data</option>
              <option value="sponsor">Devenir sponsor</option>
              <option value="freelance">Proposer mes services (freelance/consultant)</option>
              <option value="autre">Autre</option>
            </select>
          </div>
          <div class="terrain-form-group">
            <label for="terrain-message">Message</label>
            <textarea id="terrain-message" name="message" rows="5" required></textarea>
          </div>
          <input type="text" name="_gotcha" style="display:none" />
          <button type="submit" class="terrain-cta terrain-cta--primary terrain-form-submit">
            <i class="fas fa-paper-plane"></i> Envoyer
          </button>
        </form>
      </div>
    </section>

    <!-- ============================== -->
    <!-- 9. JOURNAL DU TERRAIN          -->
    <!-- ============================== -->
    <section class="terrain-section" id="journal">
      <div class="terrain-container">
        <div class="terrain-section-badge">
          <i class="fas fa-book-open"></i> JOURNAL
        </div>
        <h2 class="terrain-section-title">
          <span class="gradient-text">Journal du terrain</span>
        </h2>
        <div class="terrain-journal-timeline" id="live-journal">
          {journal.map((entry) => (
            <div class="terrain-journal-entry">
              <div class="terrain-journal-date">
                <i class="fas fa-calendar-day"></i> {entry.date}
                <span class="terrain-journal-ville">— {entry.ville}</span>
              </div>
              <h3 class="terrain-journal-titre">{entry.titre}</h3>
              <p>{entry.contenu}</p>
              <div class="terrain-journal-tags">
                {entry.tags.map((tag: string) => (
                  <span class="terrain-tag">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================== -->
    <!-- VISIBILITÉ / LIENS             -->
    <!-- ============================== -->
    <section class="terrain-section terrain-section--links" id="suivre">
      <div class="terrain-container">
        <div class="terrain-section-badge">
          <i class="fas fa-satellite-dish"></i> SUIVRE LE PROJET
        </div>
        <h2 class="terrain-section-title">
          <span class="gradient-text">Restez connectés</span>
        </h2>
        <div class="terrain-social-grid">
          <a href={projet.liens.youtube} target="_blank" rel="noopener" class="terrain-social-card terrain-social--yt">
            <i class="fab fa-youtube"></i>
            <span>YouTube</span>
            <small>Discovery IT DATA</small>
          </a>
          <a href="https://www.strava.com/athletes/49130349" target="_blank" rel="noopener" class="terrain-social-card terrain-social--strava">
            <i class="fas fa-bicycle"></i>
            <span>Strava</span>
            <small>Suivre mon parcours vélo</small>
          </a>
          <a href={projet.liens.linkedin} target="_blank" rel="noopener" class="terrain-social-card terrain-social--li">
            <i class="fab fa-linkedin"></i>
            <span>LinkedIn</span>
            <small>Stéphane Celton</small>
          </a>
          <a href="https://www.linkedin.com/company/oceanphenix" target="_blank" rel="noopener" class="terrain-social-card terrain-social--li">
            <i class="fab fa-linkedin"></i>
            <span>OceanPhenix</span>
            <small>Page entreprise</small>
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <CopyrightBar />
  <CguModal />

  <!-- Leaflet JS (self-hosted) -->
  <script src="/lib/leaflet.min.js" is:inline></script>

  <!-- Data for map scripts (CSP-safe: not executed) -->
  <script type="application/json" id="terrain-data" set:html={JSON.stringify({ etapes, position })}></script>

  <!-- Carte Leaflet init -->
  <script src="/js/terrain-maps.js" is:inline></script>

  <!-- Live-update: reads admin data from localStorage + cross-tab sync -->
  <script src="/js/terrain-live.js" is:inline></script>

</BaseLayout>
