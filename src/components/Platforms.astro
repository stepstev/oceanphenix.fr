---
// src/components/Platforms.astro
---

<section class="platforms-section" id="platforms">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">
        <i class="fas fa-rocket"></i> Écosystème
      </span>
      <h2 class="section-title fw-light">
        <i class="fas fa-layer-group icon-accent"></i>
        <span class="gradient-text">Plateformes</span>
      </h2>
      <p class="section-subtitle">
        Découvrez mon Parcours, Quelques projets, initiatives ou publications...
      </p>
    </div>

    <div class="platforms-grid">

      <!-- RAG-IA Souveraine -->
      <div class="platform-card platform-card-featured">
        <span class="new-badge" style="background: #f97316; box-shadow: 0 0 12px rgba(249,115,22,0.5);">2025</span>
        <div class="platform-header">
          <i class="platform-icon fas fa-brain"></i>
          <span class="platform-badge">IA Souveraine 2025</span>
        </div>
        <h3 class="platform-title">RAG-IA Souveraine V10 - 2025</h3>
        <p class="platform-description">
          Plateforme IA souveraine complète avec RAG (Retrieval-Augmented Generation), auto-hébergée et monitoring 360°.
          Architecture 100% souveraine garantissant la maîtrise totale de vos données et modèles IA dans un contexte professionnel exigeant.
        </p>
        <p class="platform-modules">
          <strong>Écosystème intégré 2025 :</strong> Ollama LLM • Qdrant VectorDB • OpenWebUI • API FastAPI • Grafana &amp; Prometheus • Superset BI • MinIO S3 • N8n Automation • Caddy &amp; Nginx • PostgreSQL
        </p>
        <div class="card-links-container card-links-separator">
          <div class="card-link-wrapper">
            <span class="card-link-label"><i class="fab fa-youtube"></i>Vidéo</span>
            <a href="https://www.youtube.com/watch?v=SQF49Uw_7gk" target="_blank" rel="noopener noreferrer" class="card-link-item">
              <i class="fas fa-arrow-right"></i>
              <span>youtube.com/watch?v=SQF49Uw_7gk</span>
              <i class="fas fa-external-link-alt"></i>
            </a>
          </div>
          <div class="card-link-wrapper">
            <span class="card-link-label"><i class="fab fa-github"></i>Documentation</span>
            <a href="https://github.com/stepstev/oceanphenix-IA-souveraine-v10_2026_DOCS" target="_blank" rel="noopener noreferrer" class="card-link-item">
              <i class="fas fa-arrow-right"></i>
              <span>github.com/stepstev/oceanphenix-IA-souveraine-v10_2026_DOCS</span>
              <i class="fas fa-external-link-alt"></i>
            </a>
          </div>
        </div>
      </div>

      <!-- RAG Platform 2026 Public -->
      <div class="platform-card platform-card-featured">
        <span class="new-badge">NOUVEAU</span>
        <div class="platform-header">
          <i class="platform-icon fas fa-database"></i>
          <span class="platform-badge">RAG Stack 2026</span>
        </div>
        <h3 class="platform-title">RAG Platform 2026 — Stack Publique</h3>
        <p class="platform-description">
          Nouvelle version publique de ma stack RAG 2026 : architecture modulaire, déploiement simplifié via Docker Compose,
          intégration LLM local avec Ollama, recherche vectorielle Qdrant et interface OpenWebUI.
          Conçue pour être reproductible, souveraine et adaptable à tout contexte professionnel.
        </p>
        <p class="platform-modules">
          <strong>Stack technique :</strong> Ollama LLM • Qdrant VectorDB • OpenWebUI • FastAPI • Docker Compose • LangChain • Embeddings locaux • Ingestion PDF/Web • PostgreSQL • Monitoring intégré
        </p>
        <div class="card-links-container card-links-separator">
          <div class="card-link-wrapper">
            <span class="card-link-label"><i class="fab fa-youtube"></i>Vidéo démo</span>
            <a href="https://www.youtube.com/watch?v=znjMTwqLq1k" target="_blank" rel="noopener noreferrer" class="card-link-item">
              <i class="fas fa-arrow-right"></i>
              <span>youtube.com/watch?v=znjMTwqLq1k</span>
              <i class="fas fa-external-link-alt"></i>
            </a>
          </div>
          <div class="card-link-wrapper">
            <span class="card-link-label"><i class="fab fa-github"></i>Dépôt public</span>
            <a href="https://github.com/stepstev/rag-platform-2026-public" target="_blank" rel="noopener noreferrer" class="card-link-item">
              <i class="fas fa-arrow-right"></i>
              <span>github.com/stepstev/rag-platform-2026-public</span>
              <i class="fas fa-external-link-alt"></i>
            </a>
          </div>
          <div class="card-link-wrapper" style="margin-top: 0.5rem;">
            <span class="card-link-label"><i class="fas fa-flask"></i>Page démo</span>
            <a href="/rag-2026" class="card-link-item">
              <i class="fas fa-arrow-right"></i>
              <span>oceanphenix.fr/rag-2026</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Portfolio -->
      <div class="platform-card">
        <div class="platform-header">
          <i class="platform-icon fas fa-user-circle"></i>
          <span class="platform-badge">Portfolio</span>
        </div>
        <h3 class="platform-title">Profil Professionnel</h3>
        <p class="platform-description">
          Portfolio complet avec CV interactif, parcours détaillé de 15+ ans dans l'IT, certifications professionnelles
          et vidéo de présentation. Expertise transversale en Data Product Management, BI/Analytics et Production Engineering.
        </p>
        <p class="platform-modules">
          <strong>Compétences clés :</strong> Data Product Management • Senior Data Analyst BI • Production Engineering • Architecture IA Souveraine • Stakeholder Management • Agile/Scrum • Power BI &amp; Tableau • SQL &amp; Python • CI/CD DevOps
        </p>
        <div class="card-single-link card-links-separator">
          <div class="card-link-wrapper">
            <span class="card-link-label"><i class="fas fa-globe"></i>Portfolio</span>
            <a href="https://stephanecelton.oceanphenix.fr/" target="_blank" rel="noopener noreferrer" class="card-link-item">
              <i class="fas fa-arrow-right"></i>
              <span>stephanecelton.oceanphenix.fr</span>
              <i class="fas fa-external-link-alt"></i>
            </a>
          </div>
        </div>
      </div>

      <!-- Publications LinkedIn -->
      <div class="platform-card">
        <div class="platform-header">
          <i class="platform-icon fab fa-linkedin"></i>
          <span class="platform-badge">Publications</span>
        </div>
        <h3 class="platform-title">Publications LinkedIn</h3>
        <p class="platform-description">
          Articles et partages d'expérience sur l'innovation technologique, la data, l'IA souveraine
          et les pratiques en Data Product Management et Business Intelligence.
        </p>
        <p class="platform-modules">
          <strong>Thématiques :</strong> Data Product Management • IA Souveraine • Business Intelligence • Innovation Tech • Architecture Data • Production Engineering • Transformation Digitale
        </p>
        <div class="card-single-link card-links-separator">
          <div class="card-link-wrapper">
            <span class="card-link-label"><i class="fab fa-linkedin"></i>Publications</span>
            <a href="https://www.linkedin.com/in/stephane-celton/recent-activity/all/" target="_blank" rel="noopener noreferrer" class="card-link-item">
              <i class="fas fa-arrow-right"></i>
              <span>linkedin.com/in/stephane-celton/recent-activity</span>
              <i class="fas fa-external-link-alt"></i>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
