---
// src/components/CvSection.astro
---

<section class="cv-section" id="cv">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">
        <i class="fas fa-id-card"></i> BUSINESS CARD
      </span>
      <h2 class="section-title fw-light">
        <i class="fas fa-award icon-accent"></i>
        <span class="gradient-text">Carte de Visite Professionnelle</span>
      </h2>
    </div>
    <div class="cv-card">
      <div class="cv-image-container">
        <img src="/Images/cvise.png" alt="Business Card Stéphane Celton" class="cv-image" />
      </div>
      <div class="cv-download-container">
        <a href="/Images/cvise.png" class="cv-download-btn" download="BusinessCard_Stephane_Celton.png">
          <i class="fas fa-download"></i>
          Télécharger la Business Card
        </a>
      </div>
    </div>

    <div class="cv-social-links">
      <a href="https://www.linkedin.com/company/oceanphenix/" target="_blank" rel="noopener noreferrer" class="cv-social-link cv-social-link--linkedin" aria-label="LinkedIn OceanPhenix">
        <i class="fab fa-linkedin"></i>
        <span>LinkedIn</span>
      </a>
      <a href="https://www.youtube.com/@DiscoveryITDATA" target="_blank" rel="noopener noreferrer" class="cv-social-link cv-social-link--youtube" aria-label="YouTube DiscoveryITDATA">
        <i class="fab fa-youtube"></i>
        <span>YouTube</span>
      </a>
      <a href="https://stephanecelton.oceanphenix.fr/" target="_blank" rel="noopener noreferrer" class="cv-social-link cv-social-link--portfolio" aria-label="Portfolio Stéphane Celton">
        <i class="fas fa-globe"></i>
        <span>Portfolio</span>
      </a>
    </div>
  </div>
</section>
