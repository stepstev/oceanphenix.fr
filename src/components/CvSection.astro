---
// src/components/CvSection.astro
---

<section class="cv-section" id="cv">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">
        <i class="fas fa-id-card"></i> BUSINESS CARD
      </span>
      <h2 class="section-title" style="font-weight: 300;">
        <i class="fas fa-award" style="color: var(--accent-cyan); margin-right: 0.5rem;"></i>
        <span class="gradient-text">Carte de Visite Professionnelle</span>
      </h2>
    </div>
    <div class="cv-card">
      <div class="cv-image-container">
        <img src="/Images/cvise.png" alt="Business Card Stéphane Celton" class="cv-image" />
      </div>
      <div class="cv-download-container">
        <a href="/Images/cvise.png" class="cv-download-btn" download="BusinessCard_Stephane_Celton.png">
          <i class="fas fa-download"></i>
          Télécharger la Business Card
        </a>
      </div>
    </div>
  </div>
</section>
