---
// src/components/CopyrightBar.astro
---

<div class="copyright-bar">
  <div class="copyright-content">
    <div class="last-modified">
      <i class="fas fa-clock"></i>
      <span>Dernière Modification :</span>
      <span id="last-modified-date"></span>
      <span class="last-modified-load-time">
        | Chargé : <span id="load-time"></span>
      </span>
    </div>
    <div class="copyright-main">
      ⚖️ OceanPhenix™ et oceanphenix.fr sont des marques et noms de domaine protégés. Tous droits réservés.
      <a href="#" id="cgu-link">CGU</a>
    </div>
  </div>
</div>
